{
  "$schema": "https://smallstep.com/docs/step-cli/reference/ca/provisioner/#json-schema",
  "description": "Step CA configuration for CI signing operations",
  "ca-url": "https://ca.example.com",
  "fingerprint": "REPLACE_WITH_YOUR_CA_FINGERPRINT",
  "provisioner": {
    "type": "JWK",
    "name": "ci-signing"
  },
  "certificate": {
    "subject": "skyspy-ci@github.com",
    "not-after": "24h",
    "san": [
      "skyspy-ci@github.com"
    ],
    "key-usage": [
      "digital_signature",
      "code_signing"
    ],
    "extended-key-usage": [
      "code_signing"
    ]
  }
}
