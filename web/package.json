{
  "name": "adsb-dashboard",
  "version": "2.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:e2e:all-browsers": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:e2e:full": "playwright test",
    "test:e2e:a11y": "playwright test accessibility.spec.js",
    "test:e2e:integration": "playwright test --config=e2e/integration/playwright.integration.config.js",
    "test:e2e:integration:headed": "playwright test --config=e2e/integration/playwright.integration.config.js --headed",
    "test:e2e:integration:debug": "playwright test --config=e2e/integration/playwright.integration.config.js --debug",
    "docs:screenshots": "playwright test --config=e2e/docs/playwright.docs.config.js --project=desktop --grep '.doc.js'",
    "docs:screenshots:all": "playwright test --config=e2e/docs/playwright.docs.config.js --grep '.doc.js'",
    "docs:animations": "playwright test --config=e2e/docs/playwright.docs.config.js --grep '.anim.js'",
    "docs:animations:convert": "node e2e/docs/utils/convert-all-videos.js",
    "docs:index": "node e2e/docs/utils/generate-index.js",
    "docs:generate": "npm run docs:screenshots:all && npm run docs:animations && npm run docs:animations:convert && npm run docs:index",
    "lint": "eslint src --ext .js,.jsx --report-unused-disable-directives --max-warnings 150",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css,json}\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-devtools": "^5.91.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.29.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@axe-core/react": "^4.11.0",
    "@babel/cli": "^7.23.0",
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "@chromatic-com/storybook": "^5.0.0",
    "@playwright/test": "^1.40.0",
    "@storybook/addon-a11y": "^10.2.4",
    "@storybook/addon-docs": "^10.2.4",
    "@storybook/addon-onboarding": "^10.2.4",
    "@storybook/react-vite": "^10.2.4",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^1.2.0",
    "autoprefixer": "^10.4.0",
    "cssnano": "^6.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-storybook": "^10.2.4",
    "html-minifier-terser": "^7.2.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.2.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "storybook": "^10.2.4",
    "tailwindcss": "^4.1.18",
    "terser": "^5.24.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "vitest": "^1.2.0"
  }
}
