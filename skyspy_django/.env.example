# =============================================================================
# SkysPy Django API - Environment Variables
# =============================================================================
# Copy this file to .env and customize for your deployment
# =============================================================================

# -----------------------------------------------------------------------------
# Django Settings
# -----------------------------------------------------------------------------
DEBUG=False
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production
ALLOWED_HOSTS=*

# -----------------------------------------------------------------------------
# Authentication Mode
# -----------------------------------------------------------------------------
# Options: public, private, hybrid
# - public: No authentication required (good for local/dev)
# - private: All endpoints require authentication
# - hybrid: Per-endpoint authentication (default in production)
# NOTE: even in "public" mode, AI/assistant, audio transcription, external-DB
# lookups and system internals stay auth-gated. See docs/20-public-deploy-checklist.md
AUTH_MODE=public

# -----------------------------------------------------------------------------
# SSO / OIDC (optional) — endpoints auto-discovered from the provider URL's
# .well-known/openid-configuration (Google/Auth0/Okta/Azure/Keycloak).
# Register redirect URI: https://<host>/api/v1/auth/oidc/callback/
# -----------------------------------------------------------------------------
OIDC_ENABLED=False
OIDC_PROVIDER_URL=                      # e.g. https://accounts.google.com
OIDC_PROVIDER_NAME=SSO                  # login button label
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid profile email groups
OIDC_DEFAULT_ROLE=viewer
OIDC_ALLOW_EMAIL_LINKING=False
OIDC_POST_MESSAGE_ORIGIN=

# -----------------------------------------------------------------------------
# Public-deploy hardening (production; see docs/20-public-deploy-checklist.md)
# -----------------------------------------------------------------------------
# ALLOWED_HOSTS=dashboard.example.com
# CORS_ALLOWED_ORIGINS=https://dashboard.example.com
# CSRF_TRUSTED_ORIGINS=https://dashboard.example.com   # defaults to CORS origins
# SECURE_SSL_REDIRECT=True             # set False if TLS terminates upstream only
# SECURE_HSTS_SECONDS=31536000
# REST API throttle scopes (per user-or-IP)
API_THROTTLE_ANON=600/minute
API_THROTTLE_USER=2000/minute
API_THROTTLE_AUTH=5/minute
API_THROTTLE_UPLOAD=10/minute
API_THROTTLE_EXTERNAL_LOOKUP=10/minute
API_THROTTLE_WEATHER=30/minute
API_THROTTLE_GEODATA=60/minute

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=adsb
POSTGRES_PASSWORD=adsb
POSTGRES_DB=adsb
# DATABASE_URL is constructed from the above in docker-compose

# -----------------------------------------------------------------------------
# API Port
# -----------------------------------------------------------------------------
API_PORT=8000

# -----------------------------------------------------------------------------
# ADS-B Data Sources
# -----------------------------------------------------------------------------
# Ultrafeeder (readsb/tar1090)
ULTRAFEEDER_HOST=ultrafeeder
ULTRAFEEDER_PORT=80

# Dump978 (UAT)
DUMP978_HOST=dump978
DUMP978_PORT=80

# -----------------------------------------------------------------------------
# Feeder Location (your antenna position)
# -----------------------------------------------------------------------------
FEEDER_LAT=47.9377
FEEDER_LON=-121.9687

# -----------------------------------------------------------------------------
# Polling Configuration
# -----------------------------------------------------------------------------
POLLING_INTERVAL=2
DB_STORE_INTERVAL=5
SESSION_TIMEOUT_MINUTES=30

# -----------------------------------------------------------------------------
# Safety Monitoring
# -----------------------------------------------------------------------------
SAFETY_MONITORING_ENABLED=True

# -----------------------------------------------------------------------------
# ACARS/VDL2 Configuration
# -----------------------------------------------------------------------------
ACARS_ENABLED=True
ACARS_PORT=5555
VDLM2_PORT=5556

# -----------------------------------------------------------------------------
# Notifications (Apprise URLs)
# -----------------------------------------------------------------------------
# Format: service1://...,service2://...
# Examples:
#   - telegram://bot_token/chat_id
#   - discord://webhook_id/webhook_token
#   - slack://token_a/token_b/token_c
#   - email://user:pass@smtp.example.com
APPRISE_URLS=
NOTIFICATION_COOLDOWN=300

# -----------------------------------------------------------------------------
# Photo Cache
# -----------------------------------------------------------------------------
PHOTO_CACHE_ENABLED=True
PHOTO_AUTO_DOWNLOAD=True
# Planespotters' photo API 403s a UA with no contact URL/email — set your own.
PHOTO_PLANESPOTTERS_USER_AGENT=skyspy/2.6 (+https://github.com/skyspy/skyspy)

# -----------------------------------------------------------------------------
# Radio/Audio
# -----------------------------------------------------------------------------
RADIO_ENABLED=True
RADIO_MAX_FILE_SIZE_MB=50
RADIO_RETENTION_DAYS=7

# -----------------------------------------------------------------------------
# Transcription (Whisper)
# -----------------------------------------------------------------------------
TRANSCRIPTION_ENABLED=False
WHISPER_ENABLED=False
WHISPER_URL=http://whisper:9000

# -----------------------------------------------------------------------------
# OpenSky Database
# -----------------------------------------------------------------------------
OPENSKY_DB_ENABLED=True

# -----------------------------------------------------------------------------
# OpenAIP (Global Airspace Data)
# -----------------------------------------------------------------------------
# Get a free API key at: https://www.openaip.net/
# Provides worldwide airspace boundaries, airports, and navaids
OPENAIP_ENABLED=True
OPENAIP_API_KEY=

# -----------------------------------------------------------------------------
# S3 Storage (Optional)
# -----------------------------------------------------------------------------
S3_ENABLED=False
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=

# -----------------------------------------------------------------------------
# Monitoring (Optional)
# -----------------------------------------------------------------------------
# Sentry error tracking
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Prometheus metrics
PROMETHEUS_ENABLED=True
